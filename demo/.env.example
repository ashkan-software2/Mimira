# Copy to .env.local and fill in. .env.local is gitignored.

# --- Anthropic (Claude) ---
ANTHROPIC_API_KEY=
# Defaults to claude-sonnet-4-6 if unset.
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Cohere (embeddings, multilingual v3 1024-dim) ---
COHERE_API_KEY=

# --- LINE Messaging API ---
# From the LINE Developers console for your Messaging API channel.
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=

# --- DB ---
# Optional override; default is ./data/yuna.db relative to demo/
# YUNA_DB_PATH=./data/yuna.db
