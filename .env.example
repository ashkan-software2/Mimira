# Copy to .env.local and fill in. .env.local is gitignored.

# --- LLM via OpenRouter (OpenAI-compatible) ---
# Get a key at https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=
# Default: google/gemini-2.0-flash-exp:free (free tier, supports tool use).
# Other free options that handle tool calls reasonably well:
#   meta-llama/llama-3.3-70b-instruct:free
#   deepseek/deepseek-chat-v3-0324:free
#   qwen/qwen-2.5-72b-instruct:free
# Pick from https://openrouter.ai/models?max_price=0
OPENROUTER_MODEL=google/gemini-2.0-flash-exp:free
# Optional: your app URL, surfaced on OpenRouter's dashboard.
# OPENROUTER_REFERRER=https://github.com/ashkan-software2/Mimira
# Optional: public production URL. Used to resolve local relative upload URLs.
# On Vercel, VERCEL_URL is provided automatically; for custom domains, set this.
PUBLIC_APP_URL=

# --- Clerk auth ---
# Create a Clerk app and copy the keys from its API Keys page.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/inbox
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/inbox

# --- Cohere (embeddings, multilingual v3 1024-dim) ---
# Free trial tier is sufficient for the demo (~1000 req/min on trial).
COHERE_API_KEY=

# --- LINE Messaging API ---
# From the LINE Developers console for your Messaging API channel.
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=

# --- Database (Supabase Postgres + pgvector) ---
# Two connection strings from the Supabase project (Settings → Database).
#
# DATABASE_URL: transaction-mode pooler (host ends in `.pooler.supabase.com`,
# port 6543). Used by the Next.js app at runtime. PgBouncer transaction mode
# is incompatible with prepared statements, so the client sets prepare:false.
#
# DIRECT_URL: direct connection or session-mode pooler (port 5432). Used by
# `npm run db:migrate` to apply schema.sql, because DDL (CREATE EXTENSION,
# HNSW index build) needs a normal session.
#
# Example shapes (replace [project-ref], [region], and [password]):
#   DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
#   DIRECT_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
DATABASE_URL=
DIRECT_URL=

# --- Vercel Blob (persistent chat media uploads on Vercel) ---
# Add the Blob store from Vercel Storage; Vercel injects this automatically
# when the store is connected to the project.
BLOB_READ_WRITE_TOKEN=
